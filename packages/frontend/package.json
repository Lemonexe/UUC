{
	"name": "frontend",
	"private": true,
	"version": "1.0.3",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"start": "vite",
		"build": "vite build",
		"test": "vitest run",
		"tsc": "tsc",
		"prettier": "prettier --write \"src/**/*.{ts,tsx}\"",
		"lint": "eslint src --report-unused-disable-directives --max-warnings 0",
		"lint:fix": "eslint src --fix --report-unused-disable-directives --max-warnings 0",
		"validate": "npm run lint:fix && npm run prettier && npm run tsc && npm run test"
	},
	"dependencies": {
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@vitejs/plugin-react-swc": "^4.3.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"eslint": "^9.38.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"typescript": "^6.0.2",
		"vite": "^8.0.3",
		"vitest": "^4.1.1"
	}
}
